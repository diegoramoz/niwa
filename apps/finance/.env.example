
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of this app (used by Better Auth for callbacks and redirects)
BETTER_AUTH_URL=http://localhost:3001

# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Get your access token from https://polar.sh/settings (or your org settings → API tokens)
POLAR_ACCESS_TOKEN=

# URL Polar redirects to after a successful checkout ({CHECKOUT_ID} is replaced by Polar)
POLAR_SUCCESS_URL=http://localhost:3001/success?checkout_id={CHECKOUT_ID}

# Allowed origin for CORS — set to the URL of your frontend app
CORS_ORIGIN=http://localhost:3001

# PostgreSQL connection string — e.g. from Neon (https://neon.tech), Supabase, or a local Postgres instance
DATABASE_URL=postgresql://...

# Get your token and app ID from https://uploadthing.com/dashboard → your app → API keys
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=

# Ollama local inference — optional, used for AI features
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2-vision

# Cloudflare Access credentials — required for authenticating requests to local-machine tunnel
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# local-machine tunnel URL — set to your Cloudflare tunnel hostname when running bun run start
# in packages/local-machine. Defaults to http://localhost:7001 for local dev without a tunnel.
# LOCAL_MACHINE_PING_URL=https://ping.yourdomain.com
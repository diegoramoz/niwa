# Model to use for inference (any Ollama-compatible model)
OLLAMA_MODEL=llama3.2-vision

# Base URL of the Ollama server (default: http://localhost:11434)
# Set to the Cloudflare tunnel hostname in production
OLLAMA_URL=http://localhost:11434

# Name of the named Cloudflare Tunnel (created once via `cloudflared tunnel create llm`)
CF_TUNNEL_NAME=

# Token from `cloudflared tunnel token <tunnel-name>`
CF_TUNNEL_TOKEN=
